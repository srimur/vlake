# ─────────────────────────────────────────────────────────
# V-Lake environment configuration
# Copy to `.env` and fill in real values for production.
# ─────────────────────────────────────────────────────────

# ── Blockchain ───────────────────────────────────────────
# Address of the deployed VLakeGovernance contract.
# Populated automatically by `python scripts/deploy_contract.py`.
CONTRACT_ADDRESS=

# JSON-RPC endpoint for the Besu node.
# Inside Docker the backend resolves this from docker-compose;
# only set it here if you're running the backend on the host.
BESU_RPC=http://localhost:8545

# ── Encryption-at-rest ───────────────────────────────────
# Master key (KEK) used to wrap per-dataset DEKs. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# If unset, the backend will generate a dev key on first boot
# under backend/data/.master.key — DO NOT use that in production.
VLAKE_MASTER_KEY=

# Bucket name for encrypted document blobs in MinIO.
VLAKE_ENCRYPTED_BUCKET=vlake-encrypted

# ── Object storage (MinIO / any S3) ──────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ── PostgreSQL ───────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=vlake
POSTGRES_USER=vlake
POSTGRES_PASSWORD=vlake_secret

# ── Kafka ────────────────────────────────────────────────
KAFKA_BROKER=kafka:9092

# ── MongoDB ──────────────────────────────────────────────
MONGO_URI=mongodb://mongodb:27017
MONGO_DB=vlake
