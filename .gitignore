node_modules/
artifacts/
cache/
typechain-types/
coverage/

# ── Solidity build artifacts ─────────────────────────────
# We DO ship backend/contract_abi.json — it's a function of the contract
# source, changes only when VLakeGovernance.sol changes, and lets fresh
# clones run end-to-end without an extra rebuild step. The deploy script
# overwrites it in place after a redeploy.
contracts/VLakeGovernance.json

