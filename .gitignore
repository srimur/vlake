# QBFT validator private keys for the multi-node setup.
# Regenerate locally with `besu --data-path=... public-key export-address`
# or by running scripts/setup_besu.sh — never commit them.
config/besu/keys/

# ── Python ───────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.venv/
venv/
env/
ENV/

